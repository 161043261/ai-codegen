# Server
PORT=8123

# Database
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=0406
DB_DATABASE=yu_ai_code_mother

# Redis (optional - set REDIS_ENABLED=false to disable)
REDIS_ENABLED=true
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Session
SESSION_SECRET=161043261 # your-session-secret

# JWT
JWT_SECRET=161043261 # your-jwt-secret
JWT_EXPIRES_IN=7d

# AI Provider: ollama (本地) 或 openai (云端)
LLM_PROVIDER=ollama

# AI - Ollama (本地模型)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5-coder:7b

# AI - 云端模型 (LLM_PROVIDER=openai 时使用)
OPENAI_COMPATIBLE_API_KEY=your-api-key
OPENAI_COMPATIBLE_BASE_URL=https://api.deepseek.com/v1
OPENAI_COMPATIBLE_MODEL=deepseek-chat

# Local Storage
STORAGE_PATH=./uploads
STORAGE_BASE_URL=http://localhost:8123/storage
